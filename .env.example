# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/aura_db

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
VERTEX_AI_LOCATION=us-central1

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-agent-id

# Confluent Kafka
CONFLUENT_BOOTSTRAP_SERVERS=your-confluent-bootstrap-server
CONFLUENT_API_KEY=your-confluent-api-key
CONFLUENT_API_SECRET=your-confluent-api-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID=price_your-price-id

# App Configuration
FREE_MINUTES_PER_MONTH=60
PREMIUM_PRICE=9.99

# Security
ENCRYPTION_KEY=your-encryption-key-32-chars
JWT_SECRET_KEY=your-jwt-secret-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
